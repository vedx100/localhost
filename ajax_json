<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Login</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="card">
    <h2>Login</h2>
 
    <label>Email</label>
    <input type="email" id="email" placeholder="vedant@email.com" />
    <p class="err" id="emailErr"></p>
 
    <label>Password</label>
    <input type="password" id="pass" placeholder="Password" />
    <p class="err" id="passErr"></p>
 
    <button onclick="loginUser()">Login</button>
    <p id="msg"></p>
 
    <p class="link">No account? <a href="register.html">Register</a></p>
  </div>
 
  <script>
    function loginUser() {
      document.getElementById('emailErr').textContent = '';
      document.getElementById('passErr').textContent  = '';
      document.getElementById('msg').textContent      = '';
      document.getElementById('msg').className        = '';
 
      var email = document.getElementById('email').value.trim();
      var pass  = document.getElementById('pass').value.trim();
 
      if (!email) {
        document.getElementById('emailErr').textContent = 'Enter your email.';
        return;
      }
      if (!pass) {
        document.getElementById('passErr').textContent = 'Enter your password.';
        return;
      }
 
      var xhr = new XMLHttpRequest();
      xhr.open('GET', 'users.json', true);
      xhr.onload = function() {
        var users = JSON.parse(xhr.responseText).users;
        var found = false;
        for (var i = 0; i < users.length; i++) {
          if (users[i].email === email && users[i].password === pass) {
            found = true;
            break;
          }
        }
        var msg = document.getElementById('msg');
        if (found) {
          msg.className   = 'ok';
          msg.textContent = 'Login successful!';
        } else {
          msg.className   = 'err';
          msg.textContent = 'Invalid email or password.';
        }
      };
      xhr.send();
    }
  </script>
</body>
</html>
 
 
