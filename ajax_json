* { margin: 0; padding: 0; box-sizing: border-box; }
 
body {
  background: #0d0d0f;
  color: #aaaabc;
  font-family: 'Poppins', sans-serif;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}
 
.card {
  background: #131316;
  border: 1px solid #222;
  border-radius: 12px;
  padding: 2rem 2.2rem;
  width: 100%;
  max-width: 420px;
}
 
h2 { font-size: 1.6rem; font-weight: 600; color: #f0f0f5; margin-bottom: 1rem; }
 
label { display: block; font-size: 0.82rem; margin-top: 0.9rem; margin-bottom: 0.3rem; }
 
input {
  display: block; width: 100%;
  background: #0d0d0f; border: 1px solid #222;
  color: #f0f0f5; border-radius: 7px;
  padding: 10px 14px; font-family: 'Poppins', sans-serif;
  font-size: 0.88rem; outline: none;
}
input:focus { border-color: #7c6af7; }
 
button {
  width: 100%; margin-top: 1.4rem; padding: 11px;
  background: #7c6af7; color: #fff; border: none;
  border-radius: 7px; font-family: 'Poppins', sans-serif;
  font-size: 0.9rem; cursor: pointer;
}
button:hover { opacity: 0.85; }
 
.err { font-size: 0.78rem; color: #f07070; margin-top: 0.3rem; }
.ok  { font-size: 0.82rem; color: #6bcb77; margin-top: 0.75rem; }
 
.link { font-size: 0.8rem; color: #555; margin-top: 1.2rem; text-align: center; }
.link a { color: #7c6af7; text-decoration: none; }
 
 
