// Contact form validation
function send() {
  var name  = document.getElementById('cName').value.trim();
  var email = document.getElementById('cEmail').value.trim();
  var msg   = document.getElementById('cMsg').value.trim();
  var fb    = document.getElementById('fb');

  if (!name || !email || !msg) {
    fb.className = 'err';
    fb.textContent = 'Please fill all fields.';
    return;
  }

  fb.className = 'ok';
  fb.textContent = 'Message sent! I will get back to you soon.';

  document.getElementById('cName').value  = '';
  document.getElementById('cEmail').value = '';
  document.getElementById('cMsg').value   = '';
}

var cards = document.querySelectorAll('.card');
cards.forEach(function(card) {
  card.addEventListener('mouseenter', function() {
    this.style.boxShadow = '0 8px 24px rgba(124, 106, 247, 0.15)';
  });
  card.addEventListener('mouseleave', function() {
    this.style.boxShadow = 'none';
  });
});



/css



* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  background: #0d0d0f;
  color: #aaaabc;
  font-family: 'Poppins', sans-serif;
  line-height: 1.7;
}

/* NAVBAR */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 2rem;
  background: #0d0d0f;
  border-bottom: 1px solid #222;
  z-index: 10;
}

.logo {
  font-size: 1.2rem;
  font-weight: 700;
  color: #f0f0f5;
}

.logo span {
  color: #7c6af7;
}

.links a {
  color: #aaaabc;
  text-decoration: none;
  margin-left: 1.5rem;
  font-size: 0.9rem;
  transition: color 0.2s;
}

.links a:hover {
  color: #7c6af7;
}

/* HERO */
.hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 80px 1.5rem 60px;
  animation: fadeIn 1s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(30px); }
  to   { opacity: 1; transform: translateY(0); }
}

.circle {
  width: 90px;
  height: 90px;
  border-radius: 50%;
  background: #131316;
  border: 2px solid #7c6af7;
  color: #f0f0f5;
  font-size: 1.4rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.5rem;
}

.hero h1 {
  font-size: 2.4rem;
  font-weight: 700;
  color: #f0f0f5;
  margin-bottom: 0.5rem;
}

.hero h1 span {
  color: #7c6af7;
}

.role {
  font-size: 1rem;
  margin-bottom: 0.3rem;
}

.college {
  font-size: 0.8rem;
  color: #555;
  letter-spacing: 0.1em;
  margin-bottom: 1.5rem;
}

.btn {
  display: inline-block;
  padding: 10px 26px;
  border: 1px solid #7c6af7;
  color: #7c6af7;
  border-radius: 6px;
  text-decoration: none;
  font-size: 0.9rem;
  transition: background 0.25s, color 0.25s;
}

.btn:hover {
  background: #7c6af7;
  color: #fff;
}

/* SECTIONS */
section {
  max-width: 860px;
  margin: 0 auto;
  padding: 80px 1.5rem;
}

#contact {
  max-width: 520px;
}

.tag {
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: #7c6af7;
  margin-bottom: 0.4rem;
}

h2 {
  font-size: 2rem;
  font-weight: 700;
  color: #f0f0f5;
  margin-bottom: 0.5rem;
}

hr {
  border: none;
  border-top: 1px solid #222;
  margin: 0.5rem 0 1.5rem;
}

/* CARDS */
.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  gap: 1rem;
  margin-top: 1.5rem;
}

.card {
  background: #131316;
  border: 1px solid #222;
  border-radius: 10px;
  padding: 1.2rem 1.4rem;
  transition: transform 0.25s, border-color 0.25s;
}

.card:hover {
  transform: translateY(-5px);
  border-color: #7c6af7;
}

.card h5 {
  font-size: 0.9rem;
  font-weight: 600;
  color: #f0f0f5;
  margin-bottom: 0.3rem;
}

.card p {
  font-size: 0.82rem;
  color: #aaaabc;
}

/* CONTACT */
.field {
  display: block;
  width: 100%;
  background: #131316;
  border: 1px solid #222;
  color: #f0f0f5;
  border-radius: 7px;
  padding: 10px 14px;
  font-family: 'Poppins', sans-serif;
  font-size: 0.9rem;
  margin-bottom: 0.85rem;
  outline: none;
}

.field:focus {
  border-color: #7c6af7;
}

textarea.field {
  min-height: 120px;
  resize: vertical;
}

button {
  width: 100%;
  padding: 11px;
  background: #7c6af7;
  color: #fff;
  border: none;
  border-radius: 7px;
  font-family: 'Poppins', sans-serif;
  font-size: 0.9rem;
  cursor: pointer;
  transition: opacity 0.2s;
}

button:hover {
  opacity: 0.85;
}

#fb {
  margin-top: 0.75rem;
  font-size: 0.85rem;
}

.ok  { color: #6bcb77; }
.err { color: #f07070; }

.info {
  margin-top: 1.5rem;
  font-size: 0.82rem;
  color: #444;
}

/* FOOTER */
footer {
  text-align: center;
  padding: 1.5rem;
  font-size: 0.8rem;
  color: #444;
  border-top: 1px solid #222;
}
