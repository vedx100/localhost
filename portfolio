style.css


html { scroll-behavior: smooth; }

body {
  background-color: #000;
  color: #ccc;
  font-family: Arial, sans-serif;
  transition: background 0.3s, color 0.3s;
}
body.light { background-color: #f5f5f5; color: #222; }

/* NAVBAR */
.navbar { background-color: #000; border-bottom: 1px solid #1a1a1a; }
body.light .navbar { background-color: #fff; border-bottom: 1px solid #ddd; }
.navbar-brand { color: #fff !important; font-weight: bold; font-size: 1.3rem; text-decoration: none; }
body.light .navbar-brand { color: #000 !important; }
.nav-link { color: #555 !important; text-decoration: none; transition: color 0.2s; }
.nav-link:hover { color: #fff !important; }
body.light .nav-link { color: #999 !important; }
body.light .nav-link:hover { color: #000 !important; }

/* HERO */
.hero { min-height: 100vh; background: #000; padding: 40px 20px; }
body.light .hero { background: #f5f5f5; }
.avatar {
  width: 80px; height: 80px;
  background: #111; border: 2px solid #333; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.4rem; font-weight: bold; color: #fff;
}
body.light .avatar { background: #e0e0e0; border-color: #ccc; color: #000; }
.hero h1 { color: #fff; font-size: 2.8rem; }
body.light .hero h1 { color: #000; }
.role { color: #aaa; font-size: 1.1rem; }
.college { color: #555; font-size: 0.9rem; }
.objective { color: #555; font-style: italic; font-size: 0.95rem; }

/* SKILLS SECTION */
.skills-section { background: #000; }
body.light .skills-section { background: #f5f5f5; }

/* SECTIONS */
.page-section { padding: 100px 20px; }
.page-title { color: #fff; font-size: 2rem; font-weight: bold; }
body.light .page-title { color: #000; }
.divider { border-color: #1a1a1a; }
body.light .divider { border-color: #ddd; }

/* INFO BOXES */
.info-box {
  background: #0d0d0d; border: 1px solid #1a1a1a;
  border-radius: 10px; height: 100%; transition: border-color 0.2s;
}
.info-box:hover { border-color: #444; }
body.light .info-box { background: #fff; border-color: #ddd; }
body.light .info-box:hover { border-color: #aaa; }
.info-box h5 { color: #fff; }
body.light .info-box h5 { color: #000; }
.skill-icon { font-size: 2rem; }
.text-secondary-custom { color: #666; }
body.light .text-secondary-custom { color: #888; }

/* FORM */
.form-control { background: #0d0d0d; border: 1px solid #1a1a1a; color: #fff; border-radius: 6px; }
.form-control:focus { background: #0d0d0d; border-color: #444; color: #fff; box-shadow: none; }
.form-control::placeholder { color: #444; }
body.light .form-control { background: #fff; border-color: #ddd; color: #000; }
body.light .form-control:focus { background: #fff; border-color: #999; color: #000; box-shadow: none; }
body.light .form-control::placeholder { color: #aaa; }

/* FOOTER */
footer { border-top: 1px solid #1a1a1a; color: #333; }
body.light footer { border-top: 1px solid #ddd; color: #aaa; }



script.js

// Apply saved mode on load
if (localStorage.getItem('mode') === 'light') {
  document.body.classList.add('light');
}

function toggleMode() {
  document.body.classList.toggle('light');
  localStorage.setItem('mode', document.body.classList.contains('light') ? 'light' : 'dark');
}

