<!DOCTYPE html>
<html>
<head>
    <title>Weather App</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<div class="main">
    <h2>Weather App</h2>

    <div class="search">
        <input type="text" id="city" placeholder="Enter city">
        <button onclick="getWeather()">Search</button>
    </div>

    <div id="result"></div>
</div>

<script>
function getWeather() {
    var city = document.getElementById("city").value.trim();

    if(city === ""){
        alert("Please enter city name");
        return;
    }

    var apiKey = "756119c4c73cf2a3c3423192a750f29f";
    var url = "https://api.openweathermap.org/data/2.5/weather?q=" 
              + city + "&appid=" + apiKey + "&units=metric";

    var req = new XMLHttpRequest();
    req.open("GET", url, true);

    req.onload = function() {
        var output = document.getElementById("result");

        if(req.status == 200){
            var data = JSON.parse(req.responseText);

            var html = "";
            html += "<h3>" + data.name + "</h3>";
            html += "<p><b>Temperature:</b> " + data.main.temp + " °C</p>";
            html += "<p><b>Condition:</b> " + data.weather[0].main + "</p>";
            html += "<p><b>Humidity:</b> " + data.main.humidity + "%</p>";
            html += "<p><b>Wind:</b> " + data.wind.speed + " m/s</p>";

            output.innerHTML = html;
        } else {
            output.innerHTML = "<p>City not found</p>";
        }
    };

    req.onerror = function(){
        document.getElementById("result").innerHTML = "Error fetching data";
    };

    req.send();
}
</script>

</body>
</html>



